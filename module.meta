# Vulkan Module Metadata
# Graphics API for high-performance rendering

[info]
name = vulkan
version = 1.0.0
description = Vulkan graphics API bindings for high-performance rendering

[libs]
# Import libraries for linking (relative to module directory)
windows = windows/vulkan-1.lib
linux = linux/libvulkan.so
macos = macos/libvulkan.dylib

[defs]
# Definition files for generating import libraries (if .lib not present)
windows = windows/vulkan-1.def

[dlls]
# Runtime libraries (usually provided by GPU drivers)
# Note: vulkan-1.dll is typically in system PATH
# windows = vulkan-1.dll

[dependencies]
# Vulkan requires GLFW for window creation (optional)
